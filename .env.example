# Public-doc placeholder values.
# Copy to `.env` locally if you want shell examples in the docs to expand.
# This file is documentation only; `immy` still reads runtime config from
# `~/.immy/config.yml` unless `--config` or `$IMMY_CONFIG` says otherwise.

DEPLOY_ROOT=/volume1/media-catalog
DOCKER_ROOT=${DEPLOY_ROOT}/docker
BACKUP_ROOT=${DEPLOY_ROOT}/backup
SHARED_LIBRARY=${DEPLOY_ROOT}/library
SHARED_ORIGINALS=${DEPLOY_ROOT}/originals

COMPOSE_PROJECT=immich-stack
NAS_HOST=nas-media
MAC_HOST=mac-ml
TAILNET_DOMAIN=example.ts.net
IMMICH_PORT=2283
IMMICH_URL=https://${NAS_HOST}.${TAILNET_DOMAIN}:${IMMICH_PORT}

PG_HOST=100.64.0.10
PG_PORT=15432

DSM_USER=mediaops
MEDIA_CONTAINER_ROOT=/data
EXTERNAL_ORIGINALS_MOUNT=/mnt/external/originals
