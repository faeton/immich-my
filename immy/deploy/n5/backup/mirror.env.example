# Config for nightly-mirror.sh. Copy to `mirror.env` next to the script on the
# N5 (it is git-ignored). Every value here is the built-in default except HC_URL
# — only set the lines you need to change.

# Healthchecks dead-man's-switch. Empty = no pings (a missed run won't alert).
# Hosted:      https://hc-ping.com/<uuid>
# Self-hosted: https://<host>/ping/<uuid>
# The script appends /start and /fail itself — give the BASE check URL only.
HC_URL=

# --- vv (Synology backup target) -------------------------------------------
SSH_HOST=vv
SSH_PORT=2033
SSH_USER=faeton
#SSH_KEY=/home/faeton/.ssh/id_ed25519   # set if the key isn't the ssh default
VV_ROOT=/volume1/faeton-immi

# --- n5 (source) ------------------------------------------------------------
ORIGINALS=/mnt/tank/immich/originals
MEDIA=/mnt/tank/immich/media
ORIGINALS_DS=tank/immich/originals
MEDIA_DS=tank/immich/media
DUMP_DIR=/mnt/tank/immich/backups/nightly
PG_CONTAINER=immich_postgres
OWNER=faeton:faeton

# --- retention / guards -----------------------------------------------------
KEEP_DUMPS=14
MAX_DELETE=200          # rsync refuses to delete more than this many files in one run
MIN_DUMP_BYTES=1000000  # reject a pg_dump smaller than this (~1 MB) as bogus
KEEP_LOG_DAYS=30

# Set 1 here to make every run a dry-run. A DRY_RUN passed on the command line
# (`DRY_RUN=1 ./nightly-mirror.sh`) always overrides this value.
DRY_RUN=0
